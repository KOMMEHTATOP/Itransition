@{
    ViewData["Title"] = "Music Store";
}

@section Scripts {
    <script src="~/js/app.js"></script>
}

<!-- TOOLBAR -->
<div class="toolbar d-flex align-items-center gap-3 p-3 mb-3">
    <select id="locale" class="form-select w-auto">
        <option value="en-US">English (USA)</option>
        <option value="de-DE">German (Germany)</option>
    </select>

    <div class="d-flex align-items-center gap-2">
        <input id="seed" type="number" class="form-control" style="width:160px" value="12345" />
        <button id="randomSeed" class="btn btn-outline-secondary">🎲 Random</button>
    </div>

    <div class="d-flex align-items-center gap-2">
        <label for="likes" class="mb-0 text-nowrap">Likes: <span id="likesValue">5.0</span></label>
        <input id="likes" type="range" class="form-range" min="0" max="10" step="0.1" value="5" style="width:140px"/>
    </div>

    <div class="btn-group ms-auto">
        <button id="btnTable" class="btn btn-primary">Table</button>
        <button id="btnGallery" class="btn btn-outline-primary">Gallery</button>
    </div>
</div>

<!-- TABLE VIEW -->
<div id="tableView">
    <table class="table table-hover">
        <thead>
        <tr>
            <th>#</th>
            <th>Title</th>
            <th>Artist</th>
            <th>Album</th>
            <th>Genre</th>
            <th>Likes</th>
        </tr>
        </thead>
        <tbody id="tableBody"></tbody>
    </table>
    <nav>
        <ul class="pagination justify-content-center" id="pagination"></ul>
    </nav>
</div>

<!-- GALLERY VIEW -->
<div id="galleryView" class="d-none">
    <div id="galleryGrid" class="row row-cols-2 row-cols-md-4 g-3"></div>
    <div id="galleryLoader" class="text-center p-3 d-none">
        <div class="spinner-border"></div>
    </div>
</div>