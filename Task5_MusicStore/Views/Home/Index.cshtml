@{
    ViewData["Title"] = "Music Store";
}

@section Scripts {
    <script type="module" src="~/js/app.js"></script>
}

<!-- TOOLBAR -->
<div class="toolbar d-flex align-items-center gap-3 p-3 mb-3">
    <select id="locale" class="form-select w-auto">
        <option value="en-US">🇺🇸 English</option>
        <option value="de-DE">🇩🇪 Deutsch</option>
    </select>

    <div class="d-flex align-items-center gap-2">
        <input id="seed" type="number" class="form-control" style="width:160px" value="12345" />
        <button id="randomSeed" class="btn btn-outline-secondary">🎲 Random</button>
    </div>

    <div class="d-flex align-items-center gap-2">
        <label for="likes" class="mb-0 text-nowrap">Likes: <span id="likesValue">5.0</span></label>
        <input id="likes" type="range" class="form-range" min="0" max="10" step="0.1" value="5" style="width:140px"/>
    </div>
    <button id="themeToggle" class="theme-btn" title="Toggle theme">🌙</button>
    <div class="view-switcher ms-auto">
        <button id="btnTable" class="view-btn active">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 4h18v2H3V4zm0 7h18v2H3v-2zm0 7h18v2H3v-2z"/>
            </svg>
            Table
        </button>
        <button id="btnGallery" class="view-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 3h8v8H3V3zm10 0h8v8h-8V3zM3 13h8v8H3v-8zm10 0h8v8h-8v-8z"/>
            </svg>
            Gallery
        </button>
    </div>
</div>

<!-- TABLE VIEW -->
<div id="tableView">
    <table class="table table-hover">
        <thead>
        <tr>
            <th>#</th>
            <th>Title</th>
            <th>Artist</th>
            <th>Album</th>
            <th>Genre</th>
            <th>Likes</th>
        </tr>
        </thead>
        <tbody id="tableBody"></tbody>
    </table>
    <nav>
        <ul class="pagination justify-content-center" id="pagination"></ul>
    </nav>
</div>

<!-- GALLERY VIEW -->
<div id="galleryView" class="d-none">
    <div id="galleryGrid" class="row row-cols-2 row-cols-md-4 g-3"></div>
    <div id="galleryLoader" class="text-center p-3 d-none">
        <div class="spinner-border"></div>
    </div>
</div>