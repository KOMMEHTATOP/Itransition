@model IEnumerable<Task3_AdminPlatform.Models.User>

@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>User Management</h2>
    </div>

    <form id="adminForm" method="post">
        <div class="d-flex mb-3 gap-2">
            <button type="submit" asp-action="Block" class="btn btn-warning action-button fw-bold" 
                    title="Block selected users" data-bs-toggle="tooltip" disabled>
                Block
            </button>

            <button type="submit" asp-action="Unblock" class="btn btn-outline-success action-button d-flex align-items-center justify-content-center" 
                    style="width: 45px;" title="Unblock selected users" data-bs-toggle="tooltip" disabled>
                <i class="bi bi-unlock-fill"></i>
            </button>

            <button type="submit" asp-action="Delete" class="btn btn-outline-danger action-button d-flex align-items-center justify-content-center" 
                    style="width: 45px;" title="Delete selected users" data-bs-toggle="tooltip" disabled>
                <i class="bi bi-trash-fill"></i>
            </button>

            <button type="submit" asp-action="DeleteUnverified" 
                    class="btn btn-outline-secondary d-flex align-items-center justify-content-center" 
                    style="width: 45px;" title="Delete all unverified users" data-bs-toggle="tooltip">
                <i class="bi bi-person-x-fill"></i>
            </button>
        </div>

        <table class="table table-striped table-hover border shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>
                        <input type="checkbox" id="selectAll" class="form-check-input" />
                    </th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Last Login</th>
                    <th>Registration Time</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <input type="checkbox" name="userIds" value="@user.Id" class="form-check-input user-checkbox" />
                        </td>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>@(user.LastLoginTime?.ToLocalTime().ToString("g") ?? "Never")</td>
                        <td>@user.RegistrationTime.ToLocalTime().ToString("g")</td>
                        <td>
                            @if (user.Status == "Active")
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else if (user.Status == "Blocked")
                            {
                                <span class="badge bg-danger">Blocked</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Unverified</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </form>
</div>

@section Scripts {
    <script>
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })

        const selectAll = document.getElementById('selectAll');
        const checkboxes = document.querySelectorAll('.user-checkbox');
        const buttons = document.querySelectorAll('.action-button');
        
        function updateButtonStates() {
            const anyChecked = Array.from(checkboxes).some(cb => cb.checked);
            buttons.forEach(btn => btn.disabled = !anyChecked);
        }

        if (selectAll) {
            selectAll.addEventListener('change', function() {
                checkboxes.forEach(cb => cb.checked = this.checked);
                updateButtonStates();
            });
        }

        checkboxes.forEach(cb => {
            cb.addEventListener('change', updateButtonStates);
        });

        updateButtonStates();
    </script>
}